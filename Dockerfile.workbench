# SPDX-License-Identifier: Apache-2.0
#
# Combined image: Studio Workbench (/workbench/*) + studio-assistant agent.
# The workbench reverse-proxies A2A traffic to the agent running in-process.

FROM python:3.13-slim

WORKDIR /app

COPY agents/assistant/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY agents/assistant/graph.py .
COPY agents/assistant/state.py .
COPY agents/assistant/router.py .
COPY agents/assistant/nodes.py .
COPY agents/assistant/tools.py .
COPY agents/assistant/validation.py .
COPY agents/assistant/delegate.py .
COPY agents/assistant/prompt.py .
COPY agents/assistant/langgraph.json .
COPY agents/assistant/prompt.md .
COPY agents/assistant/prompts/ /app/prompts/
COPY agents/assistant/skills/ /app/skills/

COPY workbench/ /app/workbench/

EXPOSE 8080 8090

COPY <<'EOF' /app/entrypoint.sh
#!/bin/bash
uvicorn graph:graph --host 0.0.0.0 --port 8080 &
python -m workbench.app &
wait -n
EOF
RUN chmod +x /app/entrypoint.sh

CMD ["/app/entrypoint.sh"]
